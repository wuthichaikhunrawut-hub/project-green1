{
  "name": "project-green",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "vercel-build": "npm run build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:project-green": "node dist/project-green/server/server.mjs"
